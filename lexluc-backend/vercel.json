{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/**", "lexluc-backend/prisma/**"],
        "nodepm": true
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/main.ts"
    }
  ],
  "env": {
    "CORS_ORIGIN": "https://lexlucglobalng.vercel.app,https://lexlucglobalng-back.vercel.app"
  }
}